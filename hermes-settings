#!/usr/bin/env python3
import sys

from toolkit.config import load_config, save_config, set_path, parse_value
from toolkit.status import show, status
from toolkit.logs import print_logs
from toolkit.doctor import doctor
from toolkit.profiles import apply_profile
from toolkit.models import apply_model

def usage():
    print("""Usage:
  hermes-settings show
  hermes-settings status
  hermes-settings logs
  hermes-settings doctor
  hermes-settings profile low-cost|balanced|premium
  hermes-settings model qwen|gemini|gpt
  hermes-settings set key value
""")
    sys.exit(1)

def main():
    if len(sys.argv) < 2:
        usage()

    cmd = sys.argv[1]
    cfg = load_config()

    if cmd == "show":
        show(cfg)

    elif cmd == "status":
        status(cfg)

    elif cmd == "logs":
        print_logs()

    elif cmd == "doctor":
        doctor(cfg)

    elif cmd == "profile" and len(sys.argv) == 3:
        apply_profile(cfg, sys.argv[2], set_path)
        save_config(cfg)

    elif cmd == "model" and len(sys.argv) == 3:
        apply_model(cfg, sys.argv[2], set_path)
        save_config(cfg)

    elif cmd == "set" and len(sys.argv) == 4:
        path = tuple(sys.argv[2].split("."))
        value = parse_value(sys.argv[3])
        set_path(cfg, path, value)
        save_config(cfg)

    else:
        usage()

if __name__ == "__main__":
    main()
